{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "authService-public": {
        "AuthorizationPolicy": "anonymous",
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}",
          "Methods": [ "POST" ]
        }
      },
      "authService-protected": {
        "AuthorizationPolicy": "default",
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/api/auth/protected",
          "Methods": [ "GET" ]
        }
      },
      "userService-public": {
        "AuthorizationPolicy": "anonymous",
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/api/user/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "userService-profile": {
        "AuthorizationPolicy": "default",
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/api/user/profile",
          "Methods": [ "GET" ]
        }
      },
      "userService-avatar": {
        "AuthorizationPolicy": "default",
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/api/user/avatar",
          "Methods": [ "POST", "DELETE" ]
        }
      },
      "userService-protected": {
        "AuthorizationPolicy": "default",
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/api/user/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE" ]
        }
      },
      "linkCodeService-generate": {
        "AuthorizationPolicy": "default",
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/api/link-codes",
          "Methods": [ "POST" ]
        }
      },
      "linkCodeService-validate": {
        "AuthorizationPolicy": "anonymous",
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/api/link-codes/validate",
          "Methods": [ "POST" ]
        }
      },
      "eventService-public": {
        "AuthorizationPolicy": "anonymous",
        "ClusterId": "eventCluster",
        "Match": {
          "Path": "/api/events/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "eventService-protected": {
        "AuthorizationPolicy": "default",
        "ClusterId": "eventCluster",
        "Match": {
          "Path": "/api/events/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE" ]
        }
      },
      "roomService-buildings-public": {
        "ClusterId": "roomCluster",
        "Match": {
          "Path": "/api/buildings/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "roomService-floors-public": {
        "ClusterId": "roomCluster",
        "Match": {
          "Path": "/api/floors/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "roomService-blocks-public": {
        "ClusterId": "roomCluster",
        "Match": {
          "Path": "/api/blocks/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "roomService-rooms-public": {
        "ClusterId": "roomCluster",
        "Match": {
          "Path": "/api/rooms/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "roomService-rooms-private": {
        "AuthorizationPolicy": "default",
        "ClusterId": "roomCluster",
        "Match": {
          "Path": "/api/rooms/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE" ]
        }
      },
      "roomService-maintainance-public": {
        "AuthorizationPolicy": "anonymous",
        "ClusterId": "roomCluster",
        "Match": {
          "Path": "/api/maintenance-tickets/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "roomService-maintainance-private": {
        "AuthorizationPolicy": "default",
        "ClusterId": "roomCluster",
        "Match": {
          "Path": "/api/maintenance-tickets/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE", "PATCH" ]
        }
      },
      "roomService-places-public": {
        "ClusterId": "roomCluster",
        "Match": {
          "Path": "/api/places/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "roomService-places-private": {
        "AuthorizationPolicy": "default",
        "ClusterId": "roomCluster",
        "Match": {
          "Path": "/api/places/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE", "PATCH" ]
        }
      },
      "inspectionService-public": {
        "ClusterId": "inspectionCluster",
        "Match": {
          "Path": "/api/inspections/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "inspectionService-private": {
        "AuthorizationPolicy": "anonymous",
        "ClusterId": "inspectionCluster",
        "Match": {
          "Path": "/api/inspections/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE", "PATCH" ]
        }
      },
      "notificationService-hub": {
        "AuthorizationPolicy": "default",
        "ClusterId": "notificationCluster",
        "Match": {
          "Path": "/api/notifications/hubs/{**catch-all}",
          "Methods": [ "GET", "POST" ]
        }
      },
      "notificationService-public": {
        "ClusterId": "notificationCluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "notificationService-private": {
        "AuthorizationPolicy": "default",
        "ClusterId": "notificationCluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE", "PATCH" ]
        }
      },
      "fileStorageService-public": {
        "ClusterId": "fileStorageCluster",
        "Match": {
          "Path": "/api/files/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      "fileStorageService-private": {
        "AuthorizationPolicy": "default",
        "ClusterId": "fileStorageCluster",
        "Match": {
          "Path": "/api/files/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE", "PATCH" ]
        }
      }
    },
    "Clusters": {
      "authCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://auth-service"
          }
        }
      },
      "eventCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://event-service"
          }
        }
      },
      "roomCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://room-service"
          }
        }
      },
      "inspectionCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://inspection-service"
          }
        }
      },
      "notificationCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://notification-service"
          }
        }
      },
      "fileStorageCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https+http://file-storage-service"
          }
        }
      }
    }
  }
}
