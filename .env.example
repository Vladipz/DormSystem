# Copy this file to .env and fill in your values before running docker compose.
# .env is in .gitignore and must never be committed.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=change_me_strong_password

# ── JWT  (generate secret: openssl rand -hex 64) ────────────────────────────
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64
JWT_ISSUER=http://localhost:5095
JWT_AUDIENCE=DormSystem
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ── Admin account (created automatically on first run) ──────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
